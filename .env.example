# Supabase (обязательно)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# JWT и cookie-сессия
JWT_SECRET_KEY=change-me-to-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
ACCESS_TOKEN_COOKIE_NAME=tms_access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Shared A: CMMS → TMS (контур Б ISS-API, REP-EVT-1).
# Должен совпадать с CMMS Settings → TmsIntegrationSecret.
# Пусто в dev — проверка Bearer отключена.
TMS_INTEGRATION_SECRET=

# CMMS integration (контур А: TMS → CMMS)
CMMS_INTEGRATION_MODE=mock
CMMS_SUPABASE_URL=http://127.0.0.1:54321
# publishable/anon CMMS — НЕ service_role
CMMS_SUPABASE_KEY=
# Shared B: TMS → CMMS Edge Function REP-API-1 (= CMMS_INTEGRATION_SECRET в Edge secrets)
CMMS_INTEGRATION_SECRET=
CMMS_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# Полная инструкция: docs/CMMS_INTEGRATION.md
